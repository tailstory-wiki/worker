---
import Layout from "@/layouts/Layout.astro";
import { fetchRegistry } from "@/lib/docs";
import { env } from "@/lib/env";
import { renderMarkdown } from "@/lib/markdown";

const INTRO =
  "Documentation for tools we use at Tailstory. Mostly for us, sometimes for you too.";

const registry = await fetchRegistry(env.REGISTRY);
const sortedVendors = registry
  ? [...registry.vendors].sort((a, b) => a.name.localeCompare(b.name))
  : [];
const introHtml = renderMarkdown(INTRO);
---

<Layout title="Tailstory wiki">
  <section class="hero">
    <h1 class="sr-only">Documentation index</h1>
    <div class="hero-intro" set:html={introHtml} />
  </section>
  {
    registry ? (
      <section>
        <h2 class="section-title">Vendors</h2>
        <ul class="link-list">
          {sortedVendors.map((v) => (
            <li>
              <a href={`/${v.slug}`}>{v.name}</a>
            </li>
          ))}
        </ul>
      </section>
    ) : (
      <p>Registry unavailable.</p>
    )
  }
</Layout>
