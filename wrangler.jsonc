{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wiki-site",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-08",
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true
    }
  },
  "placement": {
    "mode": "smart"
  },
  "upload_source_maps": true,
  "preview_urls": true
}
